  position: absolute;
  top: 0;
  left: 0;
  display: flex;
  overflow: hidden;
  width: 100%;
  height: 100%;
  flex-direction: column;
}
.p-scene-upsert > .app-bar {
  display: flex;
  align-items: center;
  padding: var(--spacing-xs) var(--spacing-sm);
  border-bottom: 1px solid var(--color-border-neutral);
  background: var(--color-background-neutral);
  color: var(--color-text-on-background);
  font: var(--font-heading-md);
  gap: var(--spacing-md);
  letter-spacing: var(--font-heading-md-letter-spacing);
  text-transform: var(--font-heading-md-text-transform);
}
.p-scene-upsert > .content {
  display: grid;
  overflow: auto;
  width: 100%;
  box-sizing: border-box;
  flex: 1;
  padding: 24px 64px;
  gap: 48px;
  grid-template-columns: 1fr 1fr;
}
.p-scene-upsert > .content > .settings {
  display: flex;
  overflow: auto;
  flex-direction: column;
  gap: var(--spacing-sm);
  /* TODO: consolidate these styles with token component styles */
}
.p-scene-upsert > .content > .settings > .title {
  /* Heading/sm */
  font-family: Inter;
  font-size: 16px;
  font-style: normal;
  font-weight: 700;
  line-height: 20px; /* 125% */
}
.p-scene-upsert > .content > .settings > .themes {
  display: grid;
  gap: var(--spacing-2xs);
  grid-template-columns: 1fr 1fr 1fr;
}
.p-scene-upsert > .content > .settings > .themes > .theme {
  display: flex;
  height: 50px;
  align-items: center;
  justify-content: center;
  border-radius: var(--border-radius-xs);
  background: var(--color-background-neutral-subtle);
  cursor: pointer;
}
.p-scene-upsert > .content > .settings > .themes > .theme.is-selected {
  background: var(--color-background-neutral-subtler);
}
.p-scene-upsert > .content > .settings > .themes > .theme:hover {
  background: var(--color-background-neutral-subtlest);
}
.p-scene-upsert > .content > .settings > .additional-settings > .title {
  margin-bottom: var(--spacing-sm);
  /* Overline/md */
  font-family: Inter;
  font-size: 14px;
  font-style: normal;
  font-weight: 700;
  letter-spacing: 0.8px;
  line-height: normal;
  text-transform: uppercase;
}
.p-scene-upsert > .content > .settings > .additional-settings > .settings {
  display: flex;
  flex-direction: column;
  padding: var(--spacing-sm);
  border-radius: var(--border-radius-md);
  background: var(--color-background-neutral-subtle);
  gap: var(--spacing-lg);
}
.p-scene-upsert > .content > .settings > .additional-settings > .settings > .title {
  /* Heading/sm */
  font-family: Inter;
  font-size: 16px;
  font-style: normal;
  font-weight: 700;
  line-height: 20px; /* 125% */
}
.p-scene-upsert > .content > .settings > .additional-settings > .settings > label.checkbox {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
}
.p-scene-upsert > .content > .settings > .additional-settings > .settings > label.checkbox > input {
  width: 20px;
  height: 20px;
  border: 1px solid var(--color-border-neutral);
  border-radius: var(--border-radius-xs);
  background: var(--color-background-neutral-subtle);
  cursor: pointer;
}
.p-scene-upsert > .content > .settings > .additional-settings > .settings > textarea {
  padding: var(--spacing-sm);
  border: 1px solid var(--color-border-neutral);
  border-radius: var(--border-radius-md);
  background: var(--color-background-neutral-subtle);
  color: var(--color-text-on-background);
  font: var(--font-body-md);
}
.p-scene-upsert > .content > .preview {
  display: flex;
  flex-direction: column;
  grid-gap: 12px;
}
.p-scene-upsert > .content > .preview > .title {
  color: var(--color-text-subtle-on-background);
  /* Overline/sm */
  font-family: Inter;
  font-size: 12px;
  font-style: normal;
  font-weight: 700;
  letter-spacing: 0.8px;
  line-height: 16px; /* 133.333% */
  text-transform: uppercase;
}
.p-scene-upsert > .content > .preview > .preview-container {
  overflow: hidden;
  flex: 1;
  padding: 16px;
  border: 1px solid var(--color-border-neutral);
  border-radius: var(--border-radius-md);
}

.p-app-management_p-obs_p-scene-upsert_c-chat-preview {
  height: 100%;
  with: 100%;
}
.p-app-management_p-obs_p-scene-upsert_c-chat-preview iframe {
  width: 100%;
  height: 100%;
  border: none;
