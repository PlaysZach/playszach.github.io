  grid-column-gap: 8px;
  grid-template-areas: "tip-emote author" "tip-emote body";
  grid-template-columns: 24px 1fr;
}
.c-chat-message.type-tip::before, .c-chat-message.type-sub::before, .c-chat-message.type-gift::before {
  display: block;
  width: var(--sizing-2xs);
  height: var(--sizing-2xs);
