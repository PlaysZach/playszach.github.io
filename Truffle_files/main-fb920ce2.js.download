  display: flex;
  outline: none;
}

.c-chat-input_c-editor_c-plugins_c-emote-picker-plugin_c-panel {
  display: flex;
  width: 400px;
  max-width: 100%;
  height: 360px;
  max-height: 100%;
  flex-direction: column;
  border-radius: var(--border-radius-md);
  background: var(--color-background-neutral-subtle);
  color: var(--color-text-on-background-neutral-subtler); /* FIXME: subtle not subtler */
}
.c-chat-input_c-editor_c-plugins_c-emote-picker-plugin_c-panel > .header {
  display: flex;
  padding: var(--spacing-xs);
  border-bottom: 1px solid #4a4a4a;
}
.c-chat-input_c-editor_c-plugins_c-emote-picker-plugin_c-panel > .header > .search > .input {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 4px;
  border: 1px solid rgba(255, 255, 255, 0.2);
  border-radius: var(--border-radius-xs);
  background: var(--color-background-neutral-subtler);
  color: var(--color-text-on-background-neutral-subtler);
  outline: none;
}
.c-chat-input_c-editor_c-plugins_c-emote-picker-plugin_c-panel > .header > .search > .input:focus-within {
  border-color: var(--color-border-brand);
}
.c-chat-input_c-editor_c-plugins_c-emote-picker-plugin_c-panel > .header > .close {
  margin-left: auto;
}
.c-chat-input_c-editor_c-plugins_c-emote-picker-plugin_c-panel > .content {
  position: relative; /* for tanstack virtual */
  flex: 1;
  padding: var(--spacing-xs);
  overflow-y: auto;
}
.c-chat-input_c-editor_c-plugins_c-emote-picker-plugin_c-panel > .content > .category > .emotes > .row {
  display: flex;
}`,WW=U`.c-chat-input_c-editor_c-plugins_c-emote-picker-plugin_c-panel_c-panel-emote {
  box-sizing: border-box;
  padding: var(--spacing-xs);
  cursor: pointer;
}
.c-chat-input_c-editor_c-plugins_c-emote-picker-plugin_c-panel_c-panel-emote:hover {
  background: var(--color-background-neutral-subtler);
