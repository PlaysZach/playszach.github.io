  display: grid;
  width: 370px;
  max-width: 100%;
  box-sizing: border-box;
  padding: var(--spacing-md) var(--spacing-xs);
  border: 1px solid var(--color-border-neutral);
  border-radius: var(--border-radius-md);
  background: var(--color-background-neutral-subtle);
  /* Dark/lg */
  box-shadow: 0px 12px 60px 0px rgba(0, 0, 0, 0.27), 0px 12px 32px -16px rgba(0, 0, 0, 0.5);
  color: var(--color-text-on-background);
  grid-gap: var(--spacing-md);
  outline: none;
}
.c-chat-input_c-actions_c-key-terms-popover > .header {
  display: flex;
  justify-content: space-between;
}
.c-chat-input_c-actions_c-key-terms-popover > .header > .info {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-3xs);
}
.c-chat-input_c-actions_c-key-terms-popover > .header > .info > .title {
  /* Heading/md */
  font-family: Inter;
  font-size: 20px;
  font-weight: 700;
}
.c-chat-input_c-actions_c-key-terms-popover > .header > .info > .description {
  /* Body/sm */
  font-family: Inter;
  font-size: 14px;
  font-style: normal;
  font-weight: 500;
  line-height: 20px; /* 142.857% */
}
.c-chat-input_c-actions_c-key-terms-popover > .key-terms {
  display: flex;
  min-width: 0;
  flex-direction: column;
  gap: var(--spacing-3xs);
}
.c-chat-input_c-actions_c-key-terms-popover > .key-terms > .add-key-term {
  display: flex;
  align-items: center;
  padding: var(--spacing-2xs) var(--spacing-md);
  border-radius: var(--border-radius-xs);
  background: var(--color-background-neutral-subtler);
  cursor: pointer;
  gap: var(--spacing-xs);
}
.c-chat-input_c-actions_c-key-terms-popover > .key-terms > .add-key-term:hover {
  background: var(--color-background-neutral-subtlest);
}
.c-chat-input_c-actions_c-key-terms-popover .c-chat-input_c-actions_c-key-terms-popover_c-key-term {
  display: flex;
  height: 40px;
  align-items: center;
  padding: 0 var(--spacing-md);
  border-radius: var(--border-radius-xs);
  background: var(--color-background-neutral-subtler);
  gap: var(--spacing-xs);
}
.c-chat-input_c-actions_c-key-terms-popover .c-chat-input_c-actions_c-key-terms-popover_c-key-term > input[type=color] {
  all: unset;
  overflow: hidden;
  width: 24px;
  height: 28px;
}
.c-chat-input_c-actions_c-key-terms-popover .c-chat-input_c-actions_c-key-terms-popover_c-key-term > input[type=text] {
  display: flex;
  width: 100%;
  min-width: 0;
  height: 100%;
  flex: 1;
  align-items: center;
  border: none;
  background: var(--color-background-neutral-subtler);
  color: var(--color-text-on-background-neutral-subtle);
  /* Body/sm */
  font-family: Inter;
  font-size: 14px;
  font-style: normal;
  font-weight: 500;
  line-height: 20px; /* 142.857% */
  outline: none;
}
.c-chat-input_c-actions_c-key-terms-popover .c-chat-input_c-actions_c-key-terms-popover_c-key-term > .actions {
  display: flex;
