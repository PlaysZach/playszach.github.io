  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-2xs) var(--spacing-xs);
  border-radius: var(--border-radius-sm);
  background: var(--color-background-warning);
  color: var(--color-text-on-background-warning, #000);
}
.c-chat-input_c-gate > .button {
  flex-shrink: 0;
}
.c-chat-input_c-gate > .login-overlay {
  position: fixed;
  z-index: 99;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xs);
  background: rgba(0, 0, 0, 0.5);
}
