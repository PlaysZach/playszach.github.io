  display: flex;
  flex-direction: column;
  gap: var(--spacing-xl);
  --local-prediction-color-0: #5c9edc;
  --local-prediction-color-1: #e04c70;
  --local-prediction-color-2: #e0a158;
  --local-prediction-color-3: #a0c05b;
}
.c-prediction > .header {
  text-align: center;
}
.c-prediction > .header > .question {
  font: var(--font-heading-lg);
  letter-spacing: var(--font-heading-lg-letter-spacing);
  text-transform: var(--font-heading-lg-text-transform);
}
.c-prediction > .header > .winner {
  font: var(--font-overline-md);
  letter-spacing: var(--font-overline-md-letter-spacing);
  text-transform: var(--font-overline-md-text-transform);
}
.c-prediction > .header > .status {
  color: var(--color-text-subtle-on-background);
  font: var(--font-body-md);
  letter-spacing: var(--font-body-md-letter-spacing);
  text-transform: var(--font-body-md-text-transform);
}
.c-prediction > .options {
  display: grid;
  gap: var(--spacing-sm);
  grid-template-columns: 1fr 1fr;
}
.c-prediction > .options > .option:nth-child(4n+1) {
  --local-prediction-color: var(--local-prediction-color-0);
}
.c-prediction > .options > .option:nth-child(4n+2) {
  --local-prediction-color: var(--local-prediction-color-1);
}
.c-prediction > .options > .option:nth-child(4n+3) {
  --local-prediction-color: var(--local-prediction-color-2);
}
.c-prediction > .options > .option:nth-child(4n) {
  --local-prediction-color: var(--local-prediction-color-3);
}
.c-prediction > .admin {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-sm);
}
.c-prediction > .admin > .or {
  font: var(--font-caption);
  letter-spacing: var(--font-caption-letter-spacing);
  text-transform: var(--font-caption-text-transform);
}
.c-prediction > .admin > .actions {
  display: flex;
  justify-content: center;
  gap: var(--spacing-md);
}`,SZ=U`.c-prediction_c-prediction-option {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-2xs);
}
.c-prediction_c-prediction-option.has-winner:not(.is-winner) {
  opacity: 0.5;
}
.c-prediction_c-prediction-option > .text {
  color: var(--local-prediction-color);
  font: var(--font-heading-md);
  letter-spacing: var(--font-heading-md-letter-spacing);
  text-transform: var(--font-heading-md-text-transform);
}
.c-prediction_c-prediction-option > .info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-md);
  border: 1px solid var(--local-prediction-color);
  border-radius: var(--border-radius-xs);
  gap: var(--spacing-xs);
}
.c-prediction_c-prediction-option > .info > .percent {
  display: flex;
  align-items: center;
  justify-content: center;
  font: var(--font-body-lg);
  gap: var(--spacing-xs);
  letter-spacing: var(--font-body-lg-letter-spacing);
  text-align: center;
  text-transform: var(--font-body-lg-text-transform);
}
.c-prediction_c-prediction-option > .info > .stats {
  display: flex;
  flex-direction: column;
  align-self: stretch;
  gap: var(--spacing-xs);
}
.c-prediction_c-prediction-option > .info > .stats > .stat {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font: var(--font-body-md);
  letter-spacing: var(--font-body-md-letter-spacing);
  text-transform: var(--font-body-md-text-transform);
}
.c-prediction_c-prediction-option > .info > .stats > .stat > .label {
  color: var(--local-prediction-color);
  font-weight: 700;
}
.c-prediction_c-prediction-option > .form {
  position: relative;
  display: flex;
  overflow: hidden;
  height: 40px;
  border-radius: var(--border-radius-xs);
  background: var(--color-background-neutral-subtle);
}
.c-prediction_c-prediction-option > .form::before {
  position: absolute;
  top: 50%;
  left: 0;
  width: 40px;
  height: 40px;
  background: url("https://cdn.bio/assets/images/features/points/icon.svg") no-repeat center;
  content: "";
  transform: translateY(-50%);
}
.c-prediction_c-prediction-option > .form > .input {
  flex: 1;
}
.c-prediction_c-prediction-option > .form > .input > input {
  width: 100%;
  height: 100%;
  box-sizing: border-box;
  padding: 0 var(--spacing-sm) 0 40px;
  border: none;
  background: none;
  color: var(--color-text-on-background);
  outline: none;
}
.c-prediction_c-prediction-option > .form > button {
  height: 100%;
  padding: 0 var(--spacing-md);
  border: none;
  background: var(--local-prediction-color);
  color: #fff;
  cursor: pointer;
  font: var(--font-action-lg);
  letter-spacing: var(--font-action-lg-letter-spacing);
  outline: none;
  text-transform: var(--font-action-lg-text-transform);
}
.c-prediction_c-prediction-option > .form > button:disabled {
  background: var(--color-background-neutral-subtle);
  color: var(--color-text-subtle-on-background);
  cursor: not-allowed;
}
.c-prediction_c-prediction-option > .voted-for {
  font: var(--font-caption);
  letter-spacing: var(--font-caption-letter-spacing);
  text-align: left;
  text-transform: var(--font-caption-text-transform);
