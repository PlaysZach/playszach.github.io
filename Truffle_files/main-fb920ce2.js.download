  position: relative;
  display: flex;
  min-height: var(--spacing-7, 40px);
  box-sizing: border-box;
  align-items: center;
  padding: 0px var(--spacing-2, 4px);
  border: 1px solid var(--color-bg-context-outline, rgba(0, 0, 0, 0));
  border-radius: var(--radius-3-max, 10px);
  background: var(--color-bg-context, rgba(255, 255, 255, 0.07));
  font-size: 14px;
  line-height: 22px; /* same as chat-message-body */
  outline: none;
  transition: border-color 0.1s ease-in-out;
}
.c-chat-input_c-editor:hover {
  border-color: rgba(255, 255, 255, 0.5);
}
.c-chat-input_c-editor:has(.input:focus-visible) {
  border: 1px solid transparent;
  box-shadow: 0 0 3px 3px var(--color-border-brand);
  outline: none;
}
.c-chat-input_c-editor > .placeholder {
  position: absolute;
  top: 8px;
  left: 8px;
  color: rgba(255, 255, 255, 0.5);
  pointer-events: none;
}
.c-chat-input_c-editor > .input {
  flex: 1;
  outline: none;
}
.c-chat-input_c-editor > .input > p {
  margin: 0;
  /* TODO: there's probably a better way to do this */
}
.c-chat-input_c-editor > .input > p * {
  vertical-align: middle;
}
.c-chat-input_c-editor > .buttons {
  display: flex;
