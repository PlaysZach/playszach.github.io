  padding: var(--spacing-sm);
  gap: var(--spacing-xl);
  text-align: center;
}
.p-poll > .content > .header > .question {
  /* Heading/md */
  font-family: Inter;
  font-size: 20px;
  font-style: normal;
  font-weight: 700;
  line-height: 24px; /* 120% */
}
.p-poll > .content > .header > .time-left {
  color: var(--color-text-subtle-on-background);
  /* Body/md */
  font-family: Inter;
  font-feature-settings: "clig" off, "liga" off;
  font-size: 16px;
  font-weight: 500;
  line-height: 24px; /* 150% */
  text-align: center;
}
.p-poll > .content > .options {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-2xs);
}
.p-poll > .content > .options > .option {
  display: flex;
  align-items: center;
  padding: var(--spacing-2xs);
  border: 1px solid transparent;
  border-radius: var(--border-radius-xs);
  background: var(--color-background-neutral-subtler);
  cursor: pointer;
  gap: var(--spacing-2xs);
}
.p-poll > .content > .options > .option.is-selected {
  border: 1px solid var(--color-border-neutral);
}
.p-poll > .content > .options > .option.is-selected > .radio {
  position: relative;
  border-color: var(--color-border-neutral-boldest, #fff);
}
.p-poll > .content > .options > .option.is-selected > .radio:after {
  position: absolute;
  top: 3px;
  right: 3px;
  bottom: 3px;
  left: 3px;
  box-sizing: border-box;
  border-radius: 50%;
  background: var(--color-border-neutral-boldest, #fff);
  content: "";
}
.p-poll > .content > .options > .option > .radio {
  position: relative;
  width: var(--sizing-2xs);
  height: var(--sizing-2xs);
  border: 2px solid var(--color-border-neutral-bolder);
  border-radius: 50%;
}
.p-poll > .content > .options > .option > .count {
  margin-left: auto;
  /* Heading/xs */
  font-family: Inter;
  font-size: 14px;
  font-style: normal;
  font-weight: 700;
  line-height: 18px;
}
.p-poll > .content > .options > .option > .count > .number {
  color: var(--color-text-subtler-on-background);
  font-weight: 500;
}
.p-poll > .content > .actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: var(--spacing-sm);
}`,BX=U`.c-app-bar {
