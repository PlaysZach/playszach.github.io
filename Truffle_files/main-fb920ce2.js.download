-claim {
  position: relative;
  display: flex;
  height: var(--sizing-sm);
  align-items: center;
  border-radius: var(--radius-2-max);
  background: var(--color-background-neutral-subtler);
}
.c-chat-input_c-actions_c-channel-points-claim.can-claim {
  cursor: pointer;
}
.c-chat-input_c-actions_c-channel-points-claim > .point-count {
  display: flex;
  padding: 0 var(--spacing-2xs);
  font: var(--font-caption);
  gap: var(--spacing-3xs);
  letter-spacing: var(--font-caption-letter-spacing);
  text-transform: var(--font-caption-text-transform);
}
.c-chat-input_c-actions_c-channel-points-claim > .point-count > img {
  width: var(--sizing-3xs);
  height: var(--sizing-3xs);
}
.c-chat-input_c-actions_c-channel-points-claim > .claim {
  display: flex;
  height: 100%;
  align-items: center;
  padding: 0 var(--spacing-2xs);
  border-radius: 0px var(--radius-2-max) var(--radius-2-max) 0px;
  background: linear-gradient(215deg, #fcf0b7 23.28%, #f6b856 83.07%), #ffbd49;
}
.c-chat-input_c-actions_c-channel-points-claim > .animation {
  position: absolute;
  top: 0;
  right: var(--spacing-2xs);
  bottom: 0;
  color: #f6b856;
  font-size: 12px;
  font-style: normal;
  font-weight: 500;
  line-height: 20px; /* 166.667% */
  opacity: 0;
  pointer-events: none;
}
.c-chat-input_c-actions_c-channel-points-claim > .animation.is-visible {
  animation: claim-animation 2s;
  animation-fill-mode: forwards;
}

@keyframes claim-animation {
  0% {
    opacity: 1;
    transform: translateY(0);
  }
  100% {
    opacity: 0;
    transform: translateY(-100%);
  }
