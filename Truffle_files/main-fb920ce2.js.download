  display: flex;
  flex-direction: column;
  gap: var(--spacing-xl);
  text-align: center;
}
.c-poll.variant-condensed {
  gap: var(--spacing-md);
}
.c-poll.has-voted > .options > .option {
  cursor: default;
}
.c-poll.has-ended > .options > .option {
  cursor: default;
}
.c-poll.has-ended > .options > .option > .radio {
  display: none;
}
.c-poll > .options {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-2xs);
}
.c-poll > .options > .option {
  display: flex;
  align-items: center;
  padding: var(--spacing-2xs);
  border: 1px solid transparent;
  border-radius: var(--border-radius-xs);
  background: var(--color-background-neutral-subtler);
  cursor: pointer;
  /* Heading/xs */
  font-family: Inter;
  font-size: 14px;
  font-style: normal;
  font-weight: 700;
  gap: var(--spacing-2xs);
  line-height: 18px;
}
.c-poll > .options > .option.is-selected {
  border: 1px solid var(--color-border-neutral);
}
.c-poll > .options > .option.is-selected > .radio {
  position: relative;
  border-color: var(--color-border-neutral-boldest, #fff);
}
.c-poll > .options > .option.is-selected > .radio:after {
  position: absolute;
  top: 3px;
  right: 3px;
  bottom: 3px;
  left: 3px;
  box-sizing: border-box;
  border-radius: 50%;
  background: var(--color-border-neutral-boldest, #fff);
  content: "";
}
.c-poll > .options > .option.is-winner {
  border: 1px solid #ecc152;
}
.c-poll > .options > .option.is-winner:before {
  width: var(--sizing-2xs);
  height: var(--sizing-2xs);
  background: url(https://cdn.bio/assets/images/features/polls/winner.svg);
  background-size: 100%;
  content: "";
}
.c-poll > .options > .option > .radio {
  position: relative;
  width: var(--sizing-2xs);
  height: var(--sizing-2xs);
  border: 2px solid var(--color-border-neutral-bolder);
  border-radius: 50%;
}
.c-poll > .options > .option > .count {
  margin-left: auto;
  /* Heading/xs */
  font-family: Inter;
  font-size: 14px;
  font-style: normal;
  font-weight: 700;
  line-height: 18px;
}
.c-poll > .options > .option > .count > .number {
  color: var(--color-text-subtler-on-background);
  font-weight: 500;
}
.c-poll > .actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: var(--spacing-sm);
}`,hJ=H`
