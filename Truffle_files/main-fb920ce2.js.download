  cursor: pointer;
}
.c-countable-pill.has-get-more > .countable {
  border-bottom-right-radius: 0;
  border-top-right-radius: 0;
}
.c-countable-pill.countable-sparks > .countable > .icon {
  background-image: url(https://cdn.bio/assets/images/features/sparks/icon.svg);
}
.c-countable-pill.countable-points > .countable > .icon {
  background-image: url(https://cdn.bio/assets/images/features/points/icon.svg);
}
.c-countable-pill > .countable {
  display: flex;
  height: 100%;
  box-sizing: border-box;
  align-items: center;
  padding: 0 var(--spacing-2xs);
  border-radius: 16px;
  background: var(--color-background-neutral-subtler);
  gap: var(--spacing-3xs);
}
.c-countable-pill > .countable > .icon {
  width: 14px;
  height: 14px;
  background-size: 100%;
}
