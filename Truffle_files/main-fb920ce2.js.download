  outline: none;
}

.tui-hover-tooltip {
  display: inline-flex;
  max-width: 200px;
  align-items: flex-start;
  justify-content: flex-end;
  /* padding: var(--spacing-1) var(--spacing-2); */
  padding: 4px 8px;
  border: 1px solid rgba(255, 255, 255, 0.3);
  border-radius: var(--border-radius-xs);
  background: var(--color-background-neutral-subtle);
  color: var(--color-text-on-background-neutral-subtler);
  cursor: default;
  gap: var(--spacing-3);
  text-align: center;
  /* fixes FF gap */
  transform: translate3d(0, 0, 0);
  --local-border: rgba(255, 255, 255, 0.3);
}
.tui-hover-tooltip > .arrow > svg {
  display: block;
  fill: var(--color-background-neutral-subtle);
}
.tui-hover-tooltip[data-placement=top] {
  margin-bottom: 8px;
  --origin: translateY(4px);
}
.tui-hover-tooltip[data-placement=bottom] {
  margin-top: 8px;
  --origin: translateY(-4px);
}
.tui-hover-tooltip[data-placement=bottom] > .arrow > svg {
  transform: rotate(180deg);
}
.tui-hover-tooltip[data-placement=right] {
  margin-left: 8px;
  --origin: translateX(-4px);
}
.tui-hover-tooltip[data-placement=right] > .arrow > svg {
  transform: rotate(90deg);
}
.tui-hover-tooltip[data-placement=left] {
  margin-right: 8px;
  --origin: translateX(4px);
}
.tui-hover-tooltip[data-placement=left] > .arrow > svg {
  transform: rotate(-90deg);
}
.tui-hover-tooltip[data-entering] {
  animation: slide 200ms;
}
.tui-hover-tooltip[data-exiting] {
  animation: slide 200ms reverse ease-in;
}

@keyframes slide {
  from {
    opacity: 0;
    transform: var(--origin);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
.tui-hover-tooltip_tui-link {
