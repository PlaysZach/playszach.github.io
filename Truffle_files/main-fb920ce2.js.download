/* reset text styles */
h1,
h2,
h3,
h4,
h5,
h6,
p,
a,
label {
  all: unset;
  display: block;
}

/* bring back cursors */
a {
  cursor: pointer;
}

:root {
  /* body font sizes */
  --body-lg: 20px;
  --body-md: 16px;
  --body-sm: 14px;
  /* action font sizes */
  --action-chonk: 20px;
  --action-lg: 16px;
  --action-md: 14px;
  --action-sm: 12px;
  /* overline font sizes */
  --overline-md: 14px;
  --overline-sm: 12px;
  /* caption font sizes */
  --caption-md: 12px;
  /* heading font sizes */
  --heading-3xl: 48px;
  --heading-2xl: 40px;
  --heading-xl: 32px;
  --heading-lg: 24px;
  --heading-md: 20px;
  --heading-sm: 16px;
  --heading-xs: 14px;
  /* link font sizes */
  --link-md: 16px;
  --link-sm: 14px;
  --link-xs: 12px;
  /* font weight */
  --weight-regular: 400;
  --weight-medium: 500;
  --weight-semi-bold: 600;
  --weight-bold: 700;
  /* Heading/4xl */
  --font-heading-4xl: normal 700 48px / 58px Inter;
  --font-heading-4xl-text-transform: inherit;
  --font-heading-4xl-letter-spacing: inherit;
  /* Heading/3xl */
  --font-heading-3xl: normal 700 40px / 48px Inter;
  --font-heading-3xl-text-transform: inherit;
  --font-heading-3xl-letter-spacing: inherit;
  /* Heading/2xl */
  --font-heading-2xl: normal 700 32px / 40px Inter;
  --font-heading-2xl-text-transform: inherit;
  --font-heading-2xl-letter-spacing: inherit;
  /* Heading/lg */
  --font-heading-lg: normal 700 24px / 30px Inter;
  --font-heading-lg-text-transform: inherit;
  --font-heading-lg-letter-spacing: inherit;
  /* Heading/md */
  --font-heading-md: normal 700 20px / 24px Inter;
  --font-heading-md-text-transform: inherit;
  --font-heading-md-letter-spacing: inherit;
  /* Heading/sm */
  --font-heading-sm: normal 700 16px / 20px Inter;
  --font-heading-sm-text-transform: inherit;
  --font-heading-sm-letter-spacing: inherit;
  /* Heading/xs */
  --font-heading-xs: normal 700 14px / 18px Inter;
  --font-heading-xs-text-transform: inherit;
  --font-heading-xs-letter-spacing: inherit;
  /* Body/lg */
  --font-body-lg: normal 500 20px / 30px Inter;
  --font-body-lg-text-transform: inherit;
  --font-body-lg-letter-spacing: inherit;
  /* Body/md */
  --font-body-md: normal 500 16px / 24px Inter;
  --font-body-md-text-transform: inherit;
  --font-body-md-letter-spacing: inherit;
  /* Body/md-link */
  --font-body-md-link: normal 500 16px / 24px Inter;
  --font-body-md-link-text-transform: inherit;
  --font-body-md-link-letter-spacing: inherit;
  /* Body/sm */
  --font-body-sm: normal 500 14px / 20px Inter;
  --font-body-sm-text-transform: inherit;
  --font-body-sm-letter-spacing: inherit;
  /* Body/sm-link */
  --font-body-sm-link: normal 500 14px / 20px Inter;
  --font-body-sm-link-text-transform: inherit;
  --font-body-sm-link-letter-spacing: inherit;
  /* Action/xl */
  --font-action-xl: normal 600 20px / 20px Inter;
  --font-action-xl-text-transform: inherit;
  --font-action-xl-letter-spacing: inherit;
  /* Action/lg */
  --font-action-lg: normal 600 16px / 24px Inter;
  --font-action-lg-text-transform: inherit;
  --font-action-lg-letter-spacing: inherit;
  /* Action/md */
  --font-action-md: normal 600 14px / 16px Inter;
  --font-action-md-text-transform: inherit;
  --font-action-md-letter-spacing: inherit;
  /* Action/sm */
  --font-action-sm: normal 600 12px / 16px Inter;
  --font-action-sm-text-transform: inherit;
  --font-action-sm-letter-spacing: inherit;
  /* Overline/md */
  --font-overline-md: normal 700 14px / normal Inter;
  --font-overline-md-text-transform: uppercase;
  --font-overline-md-letter-spacing: 0.8px;
  /* Overline/sm */
  --font-overline-sm: normal 700 12px / 16px Inter;
  --font-overline-sm-text-transform: uppercase;
  --font-overline-sm-letter-spacing: 0.8px;
  /* Overline/xs */
  --font-overline-xs: normal 600 10px / 14px Inter;
  --font-overline-xs-text-transform: uppercase;
  --font-overline-xs-letter-spacing: inherit;
  /* Caption */
  --font-caption: normal 400 12px / 16px Inter;
  --font-caption-text-transform: inherit;
  --font-caption-letter-spacing: inherit;
}`,pd=U`:root {
