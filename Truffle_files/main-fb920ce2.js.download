`,fY=U`.c-audit-log {
  display: flex;
  flex-direction: column;
  padding: var(--spacing-2xs) var(--spacing-xs);
  gap: var(--spacing-4xs);
}
.c-audit-log > .action {
  display: flex;
  color: var(--color-text-subtle-on-background);
  font: var(--font-caption);
  gap: var(--spacing-3xs);
  letter-spacing: var(--font-caption-letter-spacing);
  text-transform: var(--font-caption-text-transform);
}
.c-audit-log > .action > .target > .toggle-visibility {
  cursor: pointer;
}
.c-audit-log > .action > .target > .toggle-visibility:hover {
  text-decoration: underline;
}
.c-audit-log > .time {
  color: var(--color-text-subtler-on-background);
  /* Caption */
  font-family: Inter;
  font-size: 12px;
