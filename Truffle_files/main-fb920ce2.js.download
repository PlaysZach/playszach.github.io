}
.tui-button.variant-ghost[data-hovered] {
  text-decoration: underline;
}
.tui-button.variant-ghost[data-disabled] {
  opacity: 0.4;
}
.tui-button.is-full-width {
  width: 100%;
}
.tui-button[data-disabled] {
  cursor: not-allowed;
