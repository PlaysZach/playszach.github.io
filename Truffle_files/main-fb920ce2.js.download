  position: relative;
  display: flex;
  width: 100%;
  height: 100%;
  flex-direction: column;
  /* not is-controlling, not has-opted-in */
}
.a-watch-parties_p-home.is-control-panel-open > .mod-panel > .control > .content {
  display: flex;
}
.a-watch-parties_p-home.has-video:not(.is-controlling):not(.has-opted-in) > .opt-in {
  display: flex;
}
.a-watch-parties_p-home > .opt-in {
  position: absolute;
  z-index: 10;
  top: 0;
  left: 0;
  display: none;
  width: 100%;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-2xs);
  background: rgba(0, 0, 0, 0.6);
  font: var(--font-heading-xs);
  letter-spacing: var(--font-heading-xs-letter-spacing);
  text-transform: var(--font-heading-xs-text-transform);
}
.a-watch-parties_p-home > .youtube-player {
  width: 100%;
  min-height: 0;
  max-height: 100%;
  aspect-ratio: 16/9;
}
.a-watch-parties_p-home > .youtube-player > .youtube-iframe {
  width: 100%;
  height: auto;
  max-height: 100%;
  aspect-ratio: 16/9;
  object-fit: contain;
}
.a-watch-parties_p-home > .empty {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font: var(--font-action-lg);
  gap: var(--spacing-xs);
  letter-spacing: var(--font-action-lg-letter-spacing);
  text-transform: var(--font-action-lg-text-transform);
}
.a-watch-parties_p-home > .empty > .icon {
  width: 140px;
  height: 140px;
  border-radius: var(--border-radius-md);
  background: url("https://cdn.bio/assets/images/features/apps/watch-parties/icon.svg");
  background-size: 100%;
}
.a-watch-parties_p-home > .mod-panel {
  display: flex;
  min-height: 0;
  flex: 1;
  flex-direction: column;
}
.a-watch-parties_p-home > .mod-panel > .control > .header {
  display: flex;
  width: 100%;
  box-sizing: border-box;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-3xs);
  background: var(--color-background-neutral-subtle);
  cursor: pointer;
  font: var(--font-heading-xs);
  gap: var(--spacing-2xs);
  letter-spacing: var(--font-heading-xs-letter-spacing);
  text-transform: var(--font-heading-xs-text-transform);
}
.a-watch-parties_p-home > .mod-panel > .control > .header > .circle {
  width: var(--sizing-4xs);
  height: var(--sizing-4xs);
  border-radius: 50%;
  background: var(--color-background-success);
}
.a-watch-parties_p-home > .mod-panel > .control > .content {
  display: none;
  max-width: 408px;
  flex-direction: column;
  padding: var(--spacing-md);
  margin: 0 auto;
  gap: var(--spacing-md);
}
.a-watch-parties_p-home > .mod-panel > .control > .content > .warning {
  padding: var(--spacing-2xs) var(--spacing-xs);
  border: 1px solid var(--color-border-warning);
  border-radius: var(--border-radius-sm);
  background: var(--color-background-warning-subtle);
  font: var(--font-body-sm);
  letter-spacing: var(--font-body-sm-letter-spacing);
  text-transform: var(--font-body-sm-text-transform);
}
.a-watch-parties_p-home > .mod-panel > .passive {
  display: flex;
  min-height: 0;
  flex: 1;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font: var(--font-heading-sm);
  gap: var(--spacing-md);
  letter-spacing: var(--font-heading-sm-letter-spacing);
  text-align: center;
  text-transform: var(--font-heading-sm-text-transform);
