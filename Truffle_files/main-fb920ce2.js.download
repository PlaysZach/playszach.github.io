  background: var(--color-background-neutral-subtle);
  /* Dark/xl */
  box-shadow: 0px 16px 64px 0px rgba(0, 0, 0, 0.61), 0px 16px 36px -20px rgba(0, 0, 0, 0.88);
  color: var(--color-text-on-background);
}
.c-custom-timeout-dialog > .content {
  display: flex;
  flex-direction: column;
  padding: var(--spacing-sm);
  gap: var(--spacing-md);
}
.c-custom-timeout-dialog > .content > .title {
  /* Heading/md */
  font-family: Inter;
  font-size: 20px;
  font-style: normal;
  font-weight: 700;
  line-height: 24px; /* 120% */
}
.c-custom-timeout-dialog > .actions {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding: var(--spacing-sm, 16px);
  gap: var(--spacing-xs);
