  position: relative;
  display: flex;
  max-height: 400px;
  flex-direction: column;
  gap: var(--spacing-lg);
  overflow-y: auto;
}
.c-shop > .header {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
}
.c-shop > .header > .info {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-3xs);
}
.c-shop > .header > .info > .title {
  /* Overline/md */
  font-family: Inter;
  font-size: 14px;
  font-style: normal;
  font-weight: 700;
  letter-spacing: 0.8px;
  line-height: normal;
  text-transform: uppercase;
}
.c-shop > .header > .info > .description {
  color: var(--color-text-subtle-on-background);
  /* Body/sm */
  font-family: Inter;
  font-size: 14px;
  font-style: normal;
  font-weight: 500;
}
.c-shop > .products {
  display: grid;
  grid-gap: var(--spacing-2xs);
  grid-template-columns: repeat(auto-fill, minmax(152px, 1fr));
}
.c-shop > .products > .product {
  display: flex;
  flex-direction: column;
  padding: var(--spacing-xs);
  border-radius: var(--border-radius-md);
  background: var(--color-background-neutral-subtler);
  cursor: pointer;
  gap: var(--spacing-xs);
}
.c-shop > .products > .product.is-more {
  justify-content: center;
  color: var(--color-text-subtle-on-background);
  cursor: default;
