.c-chat-input_c-actions_c-support-creator-popover > .actions {
  display: grid;
  grid-gap: var(--spacing-2xs);
}
.c-chat-input_c-actions_c-support-creator-popover > .actions > .action {
  display: flex;
  align-items: center;
  padding: var(--spacing-xs);
  border-radius: var(--border-radius-xs);
  background: var(--color-background-neutral-subtler);
  cursor: pointer;
  gap: var(--spacing-xs);
}
.c-chat-input_c-actions_c-support-creator-popover > .actions > .action:hover {
  background: var(--color-background-neutral-subtlest);
}
.c-chat-input_c-actions_c-support-creator-popover > .actions > .action > .info {
  flex: 1;
}
.c-chat-input_c-actions_c-support-creator-popover > .actions > .action > .info > .title {
  /* Heading/xs */
  font-family: Inter;
  font-size: 14px;
  font-weight: 700;
}
.c-chat-input_c-actions_c-support-creator-popover > .actions > .action > .info > .description {
  color: var(--color-text-subtle-on-background);
  /* Caption */
  font-family: Inter;
  font-size: 12px;
  font-weight: 400;
}

.c-chat-input_c-actions_c-support-creator-popover_c-gifted-membership-offers {
  display: grid;
  grid-gap: var(--spacing-2xs);
}
.c-chat-input_c-actions_c-support-creator-popover_c-gifted-membership-offers > .action {
  display: flex;
  align-items: center;
  padding: var(--spacing-xs);
  border-radius: var(--border-radius-xs);
  background: var(--color-background-neutral-subtler);
  cursor: pointer;
  gap: var(--spacing-xs);
}
.c-chat-input_c-actions_c-support-creator-popover_c-gifted-membership-offers > .action:hover {
  background: var(--color-background-neutral-subtlest);
}
.c-chat-input_c-actions_c-support-creator-popover_c-gifted-membership-offers > .action > .info {
  flex: 1;
}
.c-chat-input_c-actions_c-support-creator-popover_c-gifted-membership-offers > .action > .info > .title {
  /* Heading/xs */
  font-family: Inter;
  font-size: 14px;
  font-weight: 700;
}
.c-chat-input_c-actions_c-support-creator-popover_c-gifted-membership-offers > .action > .info > .description {
  color: var(--color-text-subtle-on-background);
