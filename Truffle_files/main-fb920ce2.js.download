.c-chat-input_c-editor_c-emote-typeahead-plugin_c-menu {
  all: unset;
  position: fixed;
  z-index: 100001; /* greater than donation popover */
  bottom: 48px;
  overflow: auto;
  width: 220px;
  max-height: 300px;
  box-sizing: border-box;
  padding: var(--spacing-2xs);
  margin-bottom: 40px;
  background: var(--color-background-neutral);
  color: var(--color-text-on-background);
  font-size: 14px;
}
.c-chat-input_c-editor_c-emote-typeahead-plugin_c-menu > .emote-option {
  all: unset;
  display: flex;
  /* width: 100%; */
  min-width: 0;
  align-items: center;
  padding: var(--spacing-3xs) var(--spacing-2xs);
  border: 1px solid transparent;
  border-radius: var(--border-radius-xs);
  cursor: pointer;
  gap: var(--spacing-2xs);
  transition: none;
}
.c-chat-input_c-editor_c-emote-typeahead-plugin_c-menu > .emote-option.is-selected {
  background: var(--color-background-neutral-subtle);
}
.c-chat-input_c-editor_c-emote-typeahead-plugin_c-menu > .emote-option > .text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
