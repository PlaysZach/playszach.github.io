.c-chat-input_c-editor_c-plugins_c-donate-plugin_c-panel {
  display: flex;
  width: 100%;
  max-width: 400px;
  max-height: 100%;
  flex-direction: column;
  border-radius: var(--border-radius-md);
  background: var(--color-background-neutral-subtle);
  color: var(--color-text-on-background-neutral-subtler); /* FIXME: subtle not subtler */
}
.c-chat-input_c-editor_c-plugins_c-donate-plugin_c-panel > .header {
  display: flex;
  padding: var(--spacing-xs);
}
.c-chat-input_c-editor_c-plugins_c-donate-plugin_c-panel > .header > .close {
  margin-left: auto;
}
.c-chat-input_c-editor_c-plugins_c-donate-plugin_c-panel > .content {
  position: relative; /* for tanstack virtual */
  display: flex;
  flex: 1;
  flex-direction: column;
  padding: var(--spacing-xs);
  gap: var(--spacing-md);
  overflow-y: auto;
}
.c-chat-input_c-editor_c-plugins_c-donate-plugin_c-panel > .content > .info {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-3xs);
}
.c-chat-input_c-editor_c-plugins_c-donate-plugin_c-panel > .content > .info > .title {
  font: var(--font-heading-sm);
  letter-spacing: var(--font-heading-sm-letter-spacing);
  text-transform: var(--font-heading-sm-text-transform);
}
.c-chat-input_c-editor_c-plugins_c-donate-plugin_c-panel > .content > .info > .description {
  color: var(--color-text-subtle-on-background);
  font: var(--font-body-sm);
  letter-spacing: var(--font-body-sm-letter-spacing);
  text-transform: var(--font-body-sm-text-transform);
}
.c-chat-input_c-editor_c-plugins_c-donate-plugin_c-panel > .content > .amounts {
  display: grid;
  gap: var(--spacing-xs);
  grid-template-columns: repeat(3, 1fr);
}
.c-chat-input_c-editor_c-plugins_c-donate-plugin_c-panel > .content > .amounts > .amount {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-xs);
  border: 1px solid transparent;
  border-radius: var(--border-radius-xs);
  background: var(--color-background-neutral-subtler);
  cursor: pointer;
  gap: var(--spacing-3xs);
}
.c-chat-input_c-editor_c-plugins_c-donate-plugin_c-panel > .content > .amounts > .amount:hover {
  background: var(--color-background-neutral-subtlest);
}
.c-chat-input_c-editor_c-plugins_c-donate-plugin_c-panel > .content > .amounts > .amount.is-selected {
  border: 1px solid var(--color-border-neutral-bolder);
}
