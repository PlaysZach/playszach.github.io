  /* Heading/md */
  font-family: Inter;
  font-size: 20px;
  font-weight: 700;
}
.c-banned-terms-popover > .header > .info > .description {
  /* Body/sm */
  font-family: Inter;
  font-size: 14px;
  font-style: normal;
  font-weight: 500;
  line-height: 20px; /* 142.857% */
}
.c-banned-terms-popover > .banned-terms {
