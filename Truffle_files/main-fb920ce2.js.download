`,QQ=U`.c-tickers-bar {
  display: none;
  padding: var(--spacing-2xs) var(--spacing-xs);
  gap: var(--spacing-2xs);
  overflow-x: auto;
}
.c-tickers-bar.is-open {
  display: flex;
}

.c-ticker {
  overflow: hidden;
  min-width: max-content;
  max-width: 100px;
  padding: 1px;
  border-radius: var(--border-radius-xs);
  background: var(--color-border-neutral-bold);
  cursor: pointer;
  /* TODO: move to theme code (ludwig membership tier) */
}
.c-ticker.parasocial-club {
  --local-background: #3ef78b !important;
  --local-icon-background: url(https://cdn.bio/assets/images/features/chat/tickers/sub-2.svg) !important;
  --local-text-color: #000000 !important;
}
.c-ticker:hover {
  background: var(--color-border-neutral-bolder);
}
.c-ticker.is-selected {
  background: var(--local-background);
}
.c-ticker > .content {
  position: relative;
  z-index: 1;
  display: flex;
  overflow: hidden;
  align-items: center;
  padding: 2px var(--spacing-2xs);
  border-radius: var(--border-radius-xs);
  gap: var(--spacing-2xs);
}
.c-ticker > .content > .icon {
  width: 20px;
  height: 20px;
  flex-shrink: 0;
  background-image: var(--local-icon-background);
  background-position: center;
  background-repeat: no-repeat;
  background-size: contain;
}
.c-ticker > .content > .info {
  display: grid;
  min-width: 0;
  flex: 1;
  grid-gap: var(--spacing-4xs);
}
.c-ticker > .content > .info > .amount {
  overflow: hidden;
  /* Body/sm */
  font-family: Inter;
  font-size: 14px;
  font-weight: 500;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.c-ticker > .content > .info > .name {
  overflow: hidden;
  color: var(--color-text-subtle-on-background);
  font-family: Inter;
  font-size: 10px;
  font-style: normal;
  font-weight: 400;
  text-overflow: ellipsis;
  white-space: nowrap;
}
.c-ticker > .content > .background {
  position: absolute;
  z-index: -2;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: var(--color-background-neutral);
}
.c-ticker > .content > .progress-bar {
  position: absolute;
  z-index: -1;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.c-ticker_c-progress-bar {
  height: 100%;
  background: rgba(255, 255, 255, 0.15);
  transition: width 1s ease-in-out;
}

.c-selected-ticker-popover {
  width: 100%;
  max-width: 400px;
}

.c-selected-ticker {
  width: 100%;
  box-sizing: border-box;
  padding: var(--spacing-4xs);
  border-radius: var(--border-radius-xs);
  background: var(--local-background);
  /* Dark/lg */
  box-shadow: 0px 12px 60px 0px rgba(0, 0, 0, 0.27), 0px 12px 32px -16px rgba(0, 0, 0, 0.5);
  /* TODO: move to theme code (ludwig membership tier) */
}
.c-selected-ticker.parasocial-club {
  --local-background: #3ef78b !important;
  --local-icon-background: url(https://cdn.bio/assets/images/features/chat/tickers/sub-2.svg) !important;
  --local-text-color: #000000 !important;
}
.c-selected-ticker > .header {
  display: flex;
  align-items: center;
  padding: var(--spacing-3xs) var(--spacing-2xs);
  gap: var(--spacing-2xs);
}
.c-selected-ticker > .header > .icon {
  width: 20px;
  height: 20px;
  background-image: var(--local-icon-background);
  background-position: center;
  background-repeat: no-repeat;
  background-size: contain;
  filter: brightness(0%); /* NOTE: this won't work for making the icon white */
}
.c-selected-ticker > .header > .info > .type {
  /* Overline/xs */
  font-family: Inter;
  font-size: 10px;
  font-weight: 600;
  text-transform: uppercase;
}
.c-selected-ticker > .header > .info > .amount {
  font-family: Inter;
  font-size: 14px;
  font-weight: 700;
}
.c-selected-ticker > .header > .close {
  margin-left: auto;
}
.c-selected-ticker > .content {
  display: grid;
  padding: var(--spacing-xs);
  border-radius: var(--border-radius-xs);
  background: var(--color-background-neutral);
  color: var(--color-text-on-background);
  grid-gap: var(--spacing-4xs);
}
.c-selected-ticker > .content > .body {
  font-family: Inter;
  font-size: 14px;
  font-style: normal;
