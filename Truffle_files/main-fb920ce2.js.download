  position: relative;
  display: flex;
  min-height: 0;
  flex: 1;
  flex-direction: column;
}
.c-chat.has-tickers > .chat-messages > .banners {
  top: 0;
}
.c-chat > .chat-messages-wrapper {
  position: relative;
  display: flex;
  min-height: 0;
  flex: 1;
  padding: var(--spacing-2) var(--spacing-2) 0 var(--spacing-2);
}
.c-chat > .chat-messages-wrapper > .banners {
  position: absolute;
  z-index: 10;
  top: var(--spacing-2xs);
  right: var(--spacing-xs);
  left: var(--spacing-xs);
  display: flex;
  flex-direction: column;
  gap: var(--spacing-3xs);
}
.c-chat > .chat-messages-wrapper > .chat-messages-scroller {
  display: flex;
  overflow: auto;
  flex: 1;
  flex-direction: column-reverse;
  justify-content: flex-start; /* (reversed, so this is actually flex-end) */
  padding: 8px;
  border-radius: var(--radius-4);
  background-color: var(--color-bg-chat-message-scroller, rgba(255, 255, 255, 0.07));
}
.c-chat > .chat-messages-wrapper > .chat-messages-scroller > .background {
  position: absolute;
  z-index: 0;
  top: var(--image-chat-message-scroller-top, 0);
  right: var(--image-chat-message-scroller-right, 0);
  bottom: var(--image-chat-message-scroller-bottom, 0);
  left: var(--image-chat-message-scroller-left, 0);
  display: block;
  width: 100%;
  height: 100%;
  background-image: var(--image-chat-message-scroller-src);
  background-position: var(--image-chat-message-scroller-background-position, center center);
  background-repeat: var(--image-chat-message-scroller-background-repeat, no-repeat);
  background-size: var(--image-chat-message-scroller-background-size, contain);
  content: "";
  opacity: var(--image-chat-message-scroller-opacity, 1);
}
.c-chat > .chat-messages-wrapper > .chat-messages-scroller > .logo {
  position: absolute;
  z-index: 0;
  top: var(--image-chat-message-scroller-logo-top, 0);
  right: var(--image-chat-message-scroller-logo-right, 0);
  bottom: var(--image-chat-message-scroller-logo-bottom, 0);
  left: var(--image-chat-message-scroller-logo-left, 0);
  display: block;
  width: 100%;
  height: 100%;
  background-image: var(--image-chat-message-scroller-logo-src);
  background-position: var(--image-chat-message-scroller-logo-background-position, center center);
  background-repeat: var(--image-chat-message-scroller-logo-background-repeat, no-repeat);
  background-size: var(--image-chat-message-scroller-logo-background-size, 70%);
  content: "";
  opacity: var(--image-chat-message-scroller-logo-opacity, 1);
}
.c-chat > .chat-messages-wrapper > .chat-messages-scroller > .scroll-to-bottom {
  position: absolute;
  z-index: 1;
  right: 0;
  bottom: 12px;
  left: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}
.c-chat > .chat-messages-wrapper > .chat-messages-scroller > .chat-messages {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 4px;
}
.c-chat > .chat-input {
  padding: var(--spacing-3) var(--spacing-2);
}

.c-chat_c-unpause-button {
  width: 200px;
  pointer-events: all;
}

.c-chat_c-theme-active-powerup {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  display: flex;
  overflow: hidden;
  align-items: flex-end;
  justify-content: center;
  pointer-events: none;
}
.c-chat_c-theme-active-powerup > video {
  position: absolute;
  width: 100%;
  height: 100%;
  object-fit: cover;
}`,sF=U`.c-chat-input > .reply {
  margin-bottom: var(--spacing-2xs);
}
.c-chat-input > .header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: var(--spacing-2xs);
  gap: var(--spacing-2xs);
}
.c-chat-input > .header > .name {
  flex-shrink: 0;
  padding: 4px 8px;
  border-radius: var(--radius-2-max, 8px);
  margin-bottom: var(--spacing-2);
  background: var(--color-bg-chat-input, rgba(255, 255, 255, 0.07));
  cursor: pointer;
  font-size: 14px;
}
.c-chat-input > .header > .name:hover {
  background: var(--color-background-neutral-subtle);
}
.c-chat-input > .header > .context {
  color: var(--color-text-subtle-on-background);
  font: var(--font-caption);
  font-weight: 700; /* TODO: font-caption-bold */
  letter-spacing: var(--font-caption-letter-spacing);
  text-transform: var(--font-caption-text-transform);
  /* FIXME: hover tooltip gets in way of direct descendants */
  /* FIXME: hover tooltip gets in way of direct descendants */
}
.c-chat-input > .header > .context .error {
  color: var(--color-text-danger);
}
.c-chat-input > .header > .context .mode {
  display: flex;
  align-items: center;
  gap: var(--spacing-3xs);
}
.c-chat-input > .editor {
  position: relative;
  border: 1px solid var(--color-bg-context-outline, rgba(0, 0, 0, 0));
  border-radius: 8px;
  background: var(--color-bg-chat-input, rgba(255, 255, 255, 0.07));
}
.c-chat-input > .editor > .connect {
  font-size: 13px;
  font-weight: 700;
  text-decoration: underline;
}
.c-chat-input > .actions {
  margin-top: var(--spacing-3);
