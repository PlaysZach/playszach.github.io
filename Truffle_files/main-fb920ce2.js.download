  position: relative;
  display: flex;
  max-width: 344px;
  box-sizing: border-box;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-md);
  border-radius: var(--border-radius-lg);
  background-color: var(--color-background-brand);
  box-shadow: 0px 8px 40px 0px rgba(0, 0, 0, 0.17), 0px 12px 32px -16px rgba(0, 0, 0, 0.27);
  color: var(--color-text-on-background-brand);
  gap: var(--spacing-sm);
  text-align: center;
}
.p-chat_c-onboard > .arrow {
  position: absolute;
  top: -8px;
  left: 50%;
  display: block;
  width: 0;
  height: 0;
  border-width: 0 6px 8px 6px;
  border-style: solid;
  border-color: transparent transparent var(--color-background-brand) transparent;
  transform: translateX(-50%);
}
.p-chat_c-onboard > .image {
  width: 100%;
  border-radius: var(--border-radius-md);
  aspect-ratio: 21/9;
  background: url("https://cdn.bio/assets/images/features/chat/onboard/background.png");
  background-size: 100%;
}
.p-chat_c-onboard > .info {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--spacing-3xs);
}
.p-chat_c-onboard > .info > .title {
  font: var(--font-heading-md);
  letter-spacing: var(--font-heading-md-letter-spacing);
  text-transform: var(--font-heading-md-text-transform);
}
.p-chat_c-onboard > .info > .powered-by {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--spacing-4xs) var(--spacing-2xs);
  border-radius: var(--border-radius-lg);
  background: #fff;
  color: #000;
  font: var(--font-caption);
  gap: var(--spacing-2xs);
  letter-spacing: var(--font-caption-letter-spacing);
  text-transform: var(--font-caption-text-transform);
}
.p-chat_c-onboard > .info > .powered-by > img {
  width: var(--sizing-3xs);
  height: var(--sizing-3xs);
}
.p-chat_c-onboard > .info > .description {
  font: var(--font-body-sm);
  letter-spacing: var(--font-body-sm-letter-spacing);
  text-transform: var(--font-body-sm-text-transform);
}
.p-chat_c-onboard > .actions {
  display: grid;
  gap: var(--spacing-xs);
  grid-template-columns: repeat(2, 1fr);
