  display: flex;
  flex-direction: column;
  padding: var(--spacing-xs);
  border: 1px solid var(--color-border-neutral);
  border-radius: var(--border-radius-xs);
  background: var(--color-background-neutral-subtle);
  /* Dark/lg */
  box-shadow: 0px 12px 60px 0px rgba(0, 0, 0, 0.27), 0px 12px 32px -16px rgba(0, 0, 0, 0.5);
  gap: var(--spacing-md);
}
.c-poll-banner > .header {
  display: flex;
  align-items: center;
  gap: var(--spacing-2xs);
}
.c-poll-banner > .header > .icon {
  width: var(--sizing-2xs);
  height: var(--sizing-2xs);
  background: url(https://cdn.bio/assets/images/features/polls/icon.svg);
  background-size: 100%;
}
.c-poll-banner > .header > .info {
  flex: 1;
  min-width: 0;
}
.c-poll-banner > .header > .info > .overline {
  color: #62e176;
  /* Overline/xs */
  font-family: Inter;
  font-size: 10px;
  font-style: normal;
  font-weight: 600;
  line-height: 14px; /* 140% */
  text-transform: uppercase;
}
.c-poll-banner > .header > .info > .question {
  overflow: hidden;
  /* Heading/sm */
  font-family: Inter;
  font-size: 16px;
  font-style: normal;
  font-weight: 700;
  line-height: 20px; /* 125% */
  text-overflow: ellipsis;
  white-space: nowrap;
}
.c-poll-banner > .header > .info > .time-left {
  color: var(--Neutral-600, #bbb);
  /* Caption */
  font-family: Inter;
  font-size: 12px;
  font-style: normal;
  font-weight: 400;
  letter-spacing: 0.25px;
  line-height: 16px; /* 133.333% */
}
.c-poll-banner > .header > .close {
  align-self: flex-start;
