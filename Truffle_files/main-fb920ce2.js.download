  display: flex;
  box-sizing: border-box;
  flex-direction: column;
  padding: var(--spacing-sm);
  gap: var(--spacing-lg);
}
.a-polls_p-home > .header {
  display: flex;
  align-items: center;
  padding-right: 40px;
  gap: var(--spacing-xs);
}
.a-polls_p-home > .header > .icon {
  width: var(--sizing-2xs);
  height: var(--sizing-2xs);
  background: url(https://cdn.bio/assets/images/features/polls/icon.svg);
  background-size: 100%;
}
.a-polls_p-home > .header > .info > .title {
  /* Heading/md */
  font-family: Inter;
  font-size: 20px;
  font-style: normal;
  font-weight: 700;
  line-height: 24px; /* 120% */
}
.a-polls_p-home > .header > .info > .description {
  color: var(--color-text-subtle-on-background);
  /* Body/sm */
  font-family: Inter;
  font-size: 14px;
  font-style: normal;
  font-weight: 500;
  line-height: 20px; /* 142.857% */
}
.a-polls_p-home > .header > .create {
  margin-left: auto;
}
.a-polls_p-home > .polls {
  display: grid;
  gap: var(--spacing-xs);
}
.a-polls_p-home > .polls > .title {
  /* Heading/sm */
  font-family: Inter;
  font-size: 16px;
  font-style: normal;
  font-weight: 700;
  line-height: 20px; /* 125% */
}

.c-poll-tile {
  display: flex;
  align-items: center;
  padding: var(--spacing-xs) var(--spacing-sm);
  border-radius: var(--border-radius-xs);
  background: var(--color-background-neutral-subtle);
  gap: var(--spacing-xs);
}
.c-poll-tile > .info {
  display: flex;
  flex: 1;
  flex-direction: column;
  gap: var(--spacing-4xs);
}
.c-poll-tile > .info > .winner {
  color: #ecc152;
  /* Heading/xs */
  font-family: Inter;
  font-size: 14px;
  font-style: normal;
  font-weight: 700;
  line-height: 18px;
}
.c-poll-tile > .info > .question {
  /* Heading/sm */
  font-family: Inter;
  font-size: 16px;
  font-style: normal;
  font-weight: 700;
  line-height: 20px;
}
.c-poll-tile > .info > .meta {
  color: var(--color-text-subtle-on-background);
  /* Caption */
  font-family: Inter;
  font-size: 12px;
  font-style: normal;
  font-weight: 400;
  letter-spacing: 0.25px;
  line-height: 16px; /* 133.333% */
