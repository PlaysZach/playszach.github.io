  gap: var(--spacing-xl);
}
.p-app-management > .tabs {
  display: flex;
  justify-content: center;
  border-bottom: 1px solid var(--color-border-neutral);
  gap: var(--spacing-xs);
}
.p-app-management > .tabs > .tab {
