.c-chat-input_c-actions_c-manage-raid-popover > .header {
  display: flex;
  justify-content: space-between;
}
.c-chat-input_c-actions_c-manage-raid-popover > .header > .info {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-3xs);
}
