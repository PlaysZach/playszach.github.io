.c-chat-message.type-tip, .c-chat-message.type-sub, .c-chat-message.type-gift {
  display: grid;
  align-items: center;
  padding-left: 8px;
  border-radius: var(--border-radius-2xs);
  border-left: 4px solid #f64699;
