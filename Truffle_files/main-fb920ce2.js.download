  position: relative;
  display: flex;
  width: 100%;
  height: 100%;
  flex-direction: column;
  background-color: var(--color-bg-chat, var(--color-background-neutral));
  color: var(--color-text-on-background);
  /*> .splash {
    position: absolute;
    z-index: 1;
    width: 100%;
    height: 100%;
    background-image: var(--background-logo);
    background-position: var(--background-logo-position);
    background-repeat: var(--background-logo-repeat);
    background-size: var(--background-logo-size);
    opacity: var(--background-logo-opacity);
  }

  > .background {
    position: absolute;
    z-index: 2;
    width: 100%;
    height: 100%;
    background-image: var(--images-background, var(--background-image));
    background-position: var(--background-image-position, center);
    background-repeat: var(--background-image-repeat, no-repeat);
    background-size: var(--background-image-size, 50% auto);
    opacity: var(--background-image-opacity, 0.1);
  }*/
}
.p-chat.type-youtube-video {
  overflow: hidden;
  box-sizing: border-box;
  border: 1px solid var(--color-border-neutral);
  border-radius: var(--border-radius-md);
}
.p-chat > .button {
  position: absolute;
  z-index: 3;
  bottom: 0;
  width: 100%;
}
.p-chat > .content {
  position: relative;
  z-index: 3;
  display: flex;
  min-height: 0;
  flex: 1;
  flex-direction: column;
}
.p-chat > .content > .header {
  display: flex;
  align-items: center;
  padding: var(--spacing-xs);
  background: var(--color-background-neutral);
}
.p-chat > .content > .header > .beta-tag {
  width: 45px;
  height: 20px;
  margin-left: 20px;
}
.p-chat > .content > .header > .actions {
  display: flex;
  margin-left: auto;
  gap: var(--spacing-sm);
}
.p-chat > .content > .chat {
  position: relative;
  display: flex;
  min-height: 0;
  flex: 1;
  flex-direction: column;
