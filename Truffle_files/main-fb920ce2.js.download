  display: flex;
  overflow: hidden;
  width: 400px;
  max-width: 100vw;
  max-height: 360px;
  flex-direction: column;
  border: 1px solid var(--color-border-neutral);
  border-radius: var(--border-radius-md);
}

.c-chat-identity {
  position: relative;
  display: flex;
  min-height: 0;
  flex: 1;
  flex-direction: column;
  padding: var(--spacing-md);
  background: var(--color-background-neutral-subtle);
  color: var(--color-text-on-background-neutral-subtle);
  gap: var(--spacing-md);
}
.c-chat-identity > .close {
  position: absolute;
  top: var(--spacing-xs);
  right: var(--spacing-xs);
  cursor: pointer;
}
.c-chat-identity > .header {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-3xs);
}
.c-chat-identity > .header > .title {
  font: var(--font-heading-sm);
  letter-spacing: var(--font-heading-sm-letter-spacing);
  text-transform: var(--font-heading-sm-text-transform);
}
.c-chat-identity > .header > .description {
  font: var(--font-body-sm);
  letter-spacing: var(--font-body-sm-letter-spacing);
  text-transform: var(--font-body-sm-text-transform);
}
.c-chat-identity > .content {
  display: flex;
  min-height: 0;
  flex: 1;
  flex-direction: column;
  gap: var(--spacing-md);
}
.c-chat-identity > .content > .section {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-md);
}
.c-chat-identity > .content > .section > .title {
  font: var(--font-overline-md);
  letter-spacing: var(--font-overline-md-letter-spacing);
  text-transform: var(--font-overline-md-text-transform);
}
.c-chat-identity > .content > .section > .badges {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-2xs);
}
.c-chat-identity > .content > .section > .badges > .badge {
  padding: var(--spacing-3xs);
  border: 1px solid var(--color-border-inverse);
  border-radius: var(--border-radius-xs);
}
.c-chat-identity > .content > .section > .badges > .badge.is-hidden {
  border: 1px solid transparent;
  opacity: 0.5;
}`,dQ=U`.p-app-management_p-obs_p-scene-upsert_c-design-token.depth-0 > .children {
